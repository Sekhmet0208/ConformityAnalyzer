{
  "name": "compliance-scan-core",
  "version": "0.1.0",
  "private": true,
  "description": "Lot 1 — Coeur de scan de conformite (crawler headless + analyseurs RGPD/cookies, accessibilite, mentions legales). Sortie JSON, sans UI.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "compliance-scan": "src/cli.ts"
  },
  "scripts": {
    "scan": "tsx src/cli.ts",
    "worker": "tsx src/server/worker.ts",
    "worker:watch": "tsx watch src/server/worker.ts",
    "dev:all": "node scripts/dev-all.mjs",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "browsers": "playwright install chromium"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.0",
    "bullmq": "^5.34.0",
    "commander": "^12.1.0",
    "playwright": "1.61.1",
    "tldts": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
}
