# Connexion Redis (file de jobs BullMQ). Defaut : redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# Base relationnelle : PostgreSQL (Neon en prod, ou Postgres local en dev).
# Format : postgres://user:password@host:5432/dbname?sslmode=require
# Neon fournit cette URL directement dans le dashboard.
DATABASE_URL=postgres://user:password@localhost:5432/compliance

# TLS de la base. Laisser vide pour SSL (Neon l'exige). Mettre "disable" pour un
# Postgres local sans SSL.
# DATABASE_SSL=disable

# Taille max du pool de connexions pg (defaut 10).
# DATABASE_POOL_MAX=10

# Bypass DEV pour tester gratuitement le rapport COMPLET (palier "paid").
# N'a aucun effet en production (NODE_ENV=production). Mettre a "true" en local.
ALLOW_TIER_OVERRIDE=true

# --- Stripe (Lot 3) --------------------------------------------------------
# Laisser VIDE en dev : le paiement est alors SIMULE (l'abonnement s'active
# directement au clic, sans Stripe). Renseigner pour activer le vrai Checkout.
# Utiliser les cles de TEST (sk_test_..., price_..., whsec_...).
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
